# ===== 复制本文件为 .env 后再修改实际值 =====
# 用法：cd docker && cp .env.example .env && docker compose up -d

# ===================== MySQL =====================
MYSQL_PORT=3306
MYSQL_DB=campus_exhibition
MYSQL_ROOT_PASSWORD=root

# ===================== Redis =====================
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ===================== MinIO（可选） =====================
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio123456

# ===================== 应用服务端口 =====================
SERVER_PORT=8080
ADMIN_PORT=8081
SCREEN_PORT=8082

# ===================== 人脸服务密钥（生产环境必须修改） =====================
FACE_ENCRYPT_KEY=change-me-in-production
